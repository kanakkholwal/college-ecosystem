{
  "name": "college-ecosystem",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md}\"",
    "dev:server": "turbo run dev --filter=server",
    "build:server": "turbo run build --filter=server",
    "start:server": "turbo run start --filter=server",
    "lint:server": "turbo run lint --filter=server",
    "dev:platform": "turbo run dev --filter=platform",
    "build:platform": "turbo run build --filter=platform",
    "start:platform": "turbo run start --filter=platform",
    "dev:mail": "turbo run dev --filter=mail-server",
    "build:mail": "turbo run build --filter=mail-server",
    "start:mail": "turbo run start --filter=mail-server",
    "dev:website": "turbo run dev --filter=website",
    "build:website": "turbo run build --filter=website",
    "start:website": "turbo run start --filter=website"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.5.4",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "tsup": "^8.3.5"
  },
  "packageManager": "bun@1.3.0"
}
