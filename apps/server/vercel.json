{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "installCommand": "bun install",
    "buildCommand": "bun run build && mkdir -p public",
    "outputDirectory": "public",
    "functions": {
        "api/index.ts": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api"
        }
    ]
}
